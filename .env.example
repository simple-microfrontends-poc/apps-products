# products (remote) — build/runtime configuration.
#
# Copy this template to a per-environment file (gitignored) and fill in real values:
#   cp .env.example .env.prod    # used by `npm run build:prod` (minified)
#   cp .env.example .env.dev     # used by `npm run build:dev`  (readable, source maps)
# The build picks the file via APP_ENV; plain `npm run build` / `npm run dev`
# (no APP_ENV) fall back to .env.production / .env.development. Dev runs with
# NO .env file on the fallbacks below.
#
# Precedence (first wins; a real shell env var beats the files):
#   .env.<sel>.local > .env.<sel> > .env.local > .env   (sel = APP_ENV, else the build mode)

# Where this remote's assets (incl. remoteEntry.js) are served from.
PUBLIC_PATH=http://localhost:3001/

# Backend API base URL — baked into the bundle at build time (src/lib/api.ts).
API_BASE=http://localhost:8000

# Remote entry URL of the category-picker this remote consumes.
REMOTE_CATEGORYPICKER_URL=http://localhost:3003/remoteEntry.js

# Dev server port (npm run dev only; ignored by production builds).
DEV_PORT=3001
